---
import { site } from '../data/site';
const wa = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent('Hello — Sky49 Hyderabad inquiry.')}`;
---

<a
  href={wa}
  target="_blank"
  rel="noopener noreferrer"
  id="wa-float"
  class="pointer-events-none fixed bottom-8 right-8 z-40 hidden h-14 w-14 items-center justify-center rounded-full bg-[#25D366] text-2xl text-white opacity-0 transition hover:scale-105 sm:flex"
  aria-label="Chat on WhatsApp about Sky49 Hyderabad"
>
  <span aria-hidden="true">💬</span>
</a>

<script is:inline>
  (() => {
    const btn = document.getElementById('wa-float');
    if (!btn) return;
    const threshold = () => window.innerHeight * 0.95;

    const onScroll = () => {
      if (window.scrollY > threshold()) {
        btn.classList.remove('opacity-0', 'pointer-events-none');
      } else {
        btn.classList.add('opacity-0', 'pointer-events-none');
      }
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    onScroll();
  })();
</script>
