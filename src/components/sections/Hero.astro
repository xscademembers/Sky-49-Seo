---
import { site } from '../../data/site';
---

<section
  id="hero"
  class="relative isolate overflow-hidden scroll-mt-0"
  aria-labelledby="hero-heading"
>
  <div class="absolute inset-0">
    <img
      src={site.heroImage.src}
      alt={site.heroImage.alt}
      width={site.heroImage.width}
      height={site.heroImage.height}
      class="h-full w-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div class="hero-overlay absolute inset-0" aria-hidden="true" />
  </div>

  <div class="hero-shell relative z-10 flex flex-col justify-end px-4 pb-16 pt-28 sm:px-6 lg:px-10 lg:pb-24 lg:pt-32">
    <div class="grid gap-10 lg:grid-cols-12 lg:items-end">
      <div class="lg:col-span-7">
        <p
          class="mb-4 text-xs font-medium uppercase tracking-[0.35em] text-muted"
          id="hero-eyebrow"
        >
          Ultra-luxury branded residences · Hyderabad
        </p>
        <h1
          id="hero-heading"
          class="editorial-h1 mb-6 max-w-4xl text-4xl leading-[1.08] sm:text-5xl md:text-6xl lg:text-[3.5rem] lg:leading-[1.05]"
        >
          Sky49 Tellapur — Ultra-Luxury 3 &amp; 4 BHK Apartments in Osman Nagar, Hyderabad
        </h1>
        <p class="max-w-2xl text-lg font-light leading-relaxed text-muted sm:text-xl">
          Crafted for discerning homeowners who value privacy, prestige, and long-term asset quality.
        </p>
        <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center">
          <a
            href="#contact"
            class="hero-cta inline-flex items-center justify-center bg-charcoal px-8 py-4 text-center text-xs font-semibold uppercase tracking-[0.2em] text-white transition hover:bg-gold hover:text-charcoal"
          >
            Enquire Now
          </a>
        </div>
      </div>

      <div class="hero-lead-phase2 lg:col-span-5">
        <div
          class="hero-eoi-card relative overflow-hidden rounded-3xl border border-stone/50 bg-white/92 p-6 sm:p-8"
        >
          <p class="font-serif text-3xl leading-[1.15] text-charcoal">Request a EOI</p>
          <p class="mt-2 text-sm text-muted sm:text-base">Priority callback from our advisory desk.</p>

          <form class="mt-6 space-y-4" aria-label="Hero mini phone form">
            <label class="sr-only" for="hero-eoi-phone">Phone Number</label>
            <input
              id="hero-eoi-phone"
              name="phone"
              type="tel"
              placeholder="Enter your phone number"
              class="w-full rounded-none border border-stone/50 bg-white/70 px-4 py-3 text-sm text-charcoal placeholder:text-muted focus:border-gold focus:outline-none"
              autocomplete="tel"
            />

            <a
              href="#hero-lead-form"
              class="inline-flex w-full items-center justify-center bg-charcoal px-6 py-4 text-sm font-semibold text-white transition hover:bg-gold hover:text-charcoal"
            >
              <span>Continue</span>
            </a>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const hero = document.getElementById('hero');
    if (!hero) return;

    const revealLead = () => {
      window.setTimeout(() => {
        hero.classList.add('hero-phase-2');
      }, 180);
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', revealLead, { once: true });
    } else {
      revealLead();
    }
  })();
</script>
