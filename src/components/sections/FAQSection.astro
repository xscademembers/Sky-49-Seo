---
import { faqItems } from '../../data/faq';
---

<section id="faq" class="scroll-mt-24 border-t border-stone/40 bg-beige/30 py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10">
    <div class="overflow-hidden rounded-3xl border border-stone/40 bg-charcoal shadow-[var(--shadow-card)]">
      <div class="grid lg:grid-cols-12">
        <div class="relative min-h-[420px] border-b border-white/10 lg:col-span-7 lg:min-h-[680px] lg:border-b-0 lg:border-r lg:border-white/10">
          <img
            src="/5-1024x682.png"
            alt="Sky49 tower elevation"
            class="absolute inset-0 h-full w-full object-cover"
            loading="lazy"
            decoding="async"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-charcoal/20 via-transparent to-transparent" />
          <div class="absolute inset-x-6 bottom-6 rounded-2xl border border-white/50 bg-white/90 p-4 shadow-sm sm:inset-x-8 sm:p-5">
            <p class="font-serif text-2xl text-charcoal">Have Another Questions?</p>
            <div class="mt-3 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
              <p class="text-sm text-muted">Our team is here to help you with every detail.</p>
              <a
                href="#contact"
                class="inline-flex items-center justify-center rounded-full bg-charcoal px-5 py-2 text-sm font-medium text-white transition hover:bg-gold hover:text-charcoal"
              >
                Contact Us
              </a>
            </div>
          </div>
        </div>

        <div class="bg-charcoal px-4 py-8 sm:px-6 lg:col-span-5 lg:px-8 lg:py-10">
          <p class="text-xs font-medium uppercase tracking-[0.25em] text-stone/70">FAQ</p>
          <h2 class="mt-3 font-serif text-4xl leading-[1.05] text-white md:text-5xl">
            Frequently Asked Questions
          </h2>

          <div class="mt-8 space-y-2.5">
            {
              faqItems.map((item, i) => (
                <details
                  open={i === 0}
                  class="group overflow-hidden rounded-lg border border-white/15 bg-white/95 open:bg-white/10"
                >
                  <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-4 py-3 text-sm font-medium text-charcoal group-open:text-white">
                    <span>{item.question}</span>
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      aria-hidden="true"
                      class="h-4 w-4 shrink-0 transition-transform duration-300 group-open:rotate-180"
                    >
                      <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                    </svg>
                  </summary>
                  <div class="border-t border-white/10 px-4 py-3 text-sm leading-relaxed text-stone/80">
                    {item.answer}
                  </div>
                </details>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
