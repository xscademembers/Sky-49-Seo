---
import { faqItems } from '../../data/faq';
---

<section id="faq" class="scroll-mt-24 bg-[#efefef] py-16 md:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10">
    <div class="overflow-hidden border border-black/25 bg-black">
      <div class="grid lg:grid-cols-12">
        <div class="relative min-h-[420px] border-b border-black/40 lg:col-span-7 lg:min-h-[640px] lg:border-b-0 lg:border-r lg:border-black/40">
          <img
            src="/5-1024x682.png"
            alt="Sky49 tower elevation"
            class="absolute inset-0 h-full w-full object-cover"
            loading="lazy"
            decoding="async"
          />
          <div class="absolute inset-0 bg-black/5" />
          <div class="absolute inset-x-5 bottom-4 rounded-xl bg-white/95 p-4 shadow-sm sm:inset-x-8 sm:bottom-6 sm:p-5">
            <p class="text-3xl leading-none text-charcoal">Have Another Questions?</p>
            <div class="mt-2 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
              <p class="text-xs text-muted">Our team is here to help you with every detail.</p>
              <a
                href="#contact"
                class="inline-flex items-center justify-center rounded-full bg-charcoal px-5 py-2 text-sm text-white transition hover:bg-black/80"
              >
                Contact us
              </a>
            </div>
          </div>
        </div>

        <div class="bg-black px-4 py-8 sm:px-6 lg:col-span-5 lg:px-7 lg:py-10">
          <p class="text-xs uppercase tracking-[0.2em] text-white/75">FAQ</p>
          <h2 class="mt-3 text-5xl leading-[0.95] text-white sm:text-6xl">
            Frequently Asked Questions
          </h2>

          <div class="mt-8 space-y-2">
            {
              faqItems.map((item, i) => (
                <details
                  open={i === 0}
                  class="group overflow-hidden rounded-md border border-black/20 bg-white"
                >
                  <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-3 py-2.5 text-sm text-charcoal">
                    <span>{item.question}</span>
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      aria-hidden="true"
                      class="h-4 w-4 shrink-0 transition-transform duration-300 group-open:rotate-180"
                    >
                      <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                    </svg>
                  </summary>
                  <div class="border-t border-black/10 px-3 py-3 text-sm leading-relaxed text-charcoal/75">
                    {item.answer}
                  </div>
                </details>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const faqSection = document.getElementById('faq');
    if (!faqSection) return;

    const items = Array.from(faqSection.querySelectorAll('details'));
    items.forEach((item) => {
      item.addEventListener('toggle', () => {
        if (!item.open) return;
        items.forEach((other) => {
          if (other !== item) other.open = false;
        });
      });
    });
  })();
</script>
