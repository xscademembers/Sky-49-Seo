---
import { floorPlanRows } from '../../data/site';
---

<section id="floor-plans" class="scroll-mt-24 bg-[#e9d8a8] py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10">
    <div class="max-w-4xl">
      <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-charcoal/80">Floor Plan</p>
      <h2 class="mt-3 font-serif text-4xl leading-tight text-charcoal sm:text-5xl">
        Empowering Your Decision for a Refined Dream Living
      </h2>
      <p class="mt-4 max-w-3xl text-sm leading-relaxed text-charcoal/80">
        Thoughtfully designed 3 &amp; 4 BHK luxury floor plans at SKY49 are crafted to maximize space, privacy,
        natural light, and everyday comfort.
      </p>
    </div>

    <div class="mt-10 border-t border-charcoal/25">
      {
        floorPlanRows.map((row) => (
          <article class="grid items-center gap-5 border-b border-charcoal/25 py-4 md:grid-cols-[90px_minmax(220px,1fr)_260px_220px] md:gap-x-12 md:py-6">
            <p class="text-4xl font-semibold leading-none text-charcoal">{row.label}</p>
            <h3 class="text-xl text-charcoal">{row.name}</h3>
            <img
              src={row.image}
              alt={row.name}
              class="h-60 w-80 justify-self-start border border-charcoal/15 object-cover md:h-44 md:w-44"
              loading="lazy"
              decoding="async"
            />
            <a
              href={row.brochureHref}
              class="inline-flex justify-self-start items-center justify-center rounded-full bg-charcoal px-5 py-2 text-xs font-medium text-white transition md:justify-self-end hover:bg-black"
            >
              Download Brochure →
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>
