---
const items = [
  {
    title: 'Skyline identity',
    body:
      'A vertical G+49 narrative across four towers creates a recognizable Sky49 Hyderabad silhouette—important for luxury buyers who value landmark presence and long-term address prestige in Tellapur.',
  },
  {
    title: 'Amenity depth',
    body:
      'With over 1 lakh sq ft of amenities (indicative), Sky49 is designed as a daily-use club, not a checklist—wellness, social, and family zones scale for real weekend traffic, not brochure filler.',
  },
  {
    title: 'Osman Nagar fit',
    body:
      'Osman Nagar’s growth story pairs greenfield calm with improving infrastructure—ideal for CXOs who want quieter evenings yet refuse to compromise on commute logic to Financial District and ORR.',
  },
  {
    title: '3 & 4 BHK focus',
    body:
      'Large-format 3 BHK and 4 BHK layouts prioritize light, storage, and staff movement—supporting multi-generational living and work-from-home suites without awkward retrofits later.',
  },
] as const;
---

<section id="highlights" class="scroll-mt-24 bg-beige/40 py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10">
    <figure class="mb-10 overflow-hidden rounded-3xl border border-stone/40 bg-white shadow-[var(--shadow-soft)]">
      <img
        src="/2000-x-1333-1024x682.png"
        alt="Sky49 highlights visual"
        class="h-[220px] w-full object-cover sm:h-[280px] md:h-[340px]"
        loading="lazy"
        decoding="async"
      />
    </figure>

    <div class="grid gap-10 lg:grid-cols-12 lg:gap-12">
      <div class="lg:col-span-4">
        <div class="sticky top-24 rounded-3xl border border-gold/30 bg-white p-6 shadow-[var(--shadow-soft)] sm:p-8">
          <div class="mb-4 flex items-center gap-4">
            <div class="h-px w-10 bg-gold" aria-hidden="true"></div>
            <p class="text-xs font-medium uppercase tracking-[0.25em] text-muted">Highlights</p>
          </div>
          <h2 class="font-serif text-3xl text-charcoal md:text-4xl">Why buyers shortlist Sky49 Tellapur</h2>
          <p class="mt-4 text-sm font-light leading-relaxed text-muted">
            Key decision points for premium Hyderabad buyers: skyline value, amenity utility, location logic,
            and liveability over long holding cycles.
          </p>

          <div class="mt-7 rounded-2xl border border-stone/40 bg-warm-white/95 p-4">
            <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-muted">At a glance</p>
            <div class="mt-3 space-y-2 text-sm text-charcoal">
              <p>G+49 landmark towers</p>
              <p>1 lakh+ sq ft amenities</p>
              <p>Osman Nagar, Tellapur</p>
              <p>3 &amp; 4 BHK focus</p>
            </div>
          </div>
        </div>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:col-span-8">
        {
          items.map((item, i) => (
            <article class="group rounded-2xl border border-stone/50 bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-0.5 hover:border-gold/40 hover:shadow-[var(--shadow-soft)] sm:p-7">
              <div class="flex items-center justify-between gap-3">
                <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-muted">
                  Highlight {(i + 1).toString().padStart(2, '0')}
                </p>
                <span class="h-px w-10 bg-gold/60" aria-hidden="true"></span>
              </div>
              <h3 class="mt-3 font-serif text-2xl text-charcoal">{item.title}</h3>
              <p class="mt-4 text-sm font-light leading-relaxed text-muted">{item.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
