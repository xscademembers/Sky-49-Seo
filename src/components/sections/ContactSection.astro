---
import ContactForm from '../islands/ContactForm';
import { site } from '../../data/site';
---

<section id="contact" class="scroll-mt-24 bg-stone/20 py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10">
    <div class="grid gap-10 lg:grid-cols-2 lg:gap-14">
      <div>
        <div class="mb-6 flex items-center gap-4">
          <div class="h-px w-8 bg-gold" aria-hidden="true"></div>
          <span class="text-xs font-medium uppercase tracking-[0.2em] text-muted">Contact</span>
        </div>
        <h2 class="mb-6 text-balance font-serif text-4xl leading-tight text-charcoal md:text-5xl">
          Book a site visit — Sky49 Hyderabad
        </h2>
        <p class="mb-10 max-w-md text-lg font-light leading-relaxed text-muted">
          Share your details for <strong>Sky49 Tellapur</strong> pricing, floor plans, and a curated walkthrough.
          Home loan assistance and brochure delivery available through the desk.
        </p>

        <div class="mb-8 flex flex-wrap gap-3">
          <span class="rounded-full border border-gold/30 bg-white px-4 py-2 text-[10px] font-semibold uppercase tracking-wider text-charcoal">
            RERA disclosure on request
          </span>
          <span class="rounded-full border border-stone/50 bg-white px-4 py-2 text-[10px] font-semibold uppercase tracking-wider text-charcoal">
            {site.builder}
          </span>
          <span class="rounded-full border border-stone/50 bg-white px-4 py-2 text-[10px] font-semibold uppercase tracking-wider text-charcoal">
            Home loans — leading banks
          </span>
        </div>

        <div class="space-y-8">
          <div class="flex gap-4">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-stone bg-white shadow-sm">
              <span aria-hidden="true" class="text-gold">☎</span>
            </div>
            <div>
              <p class="mb-1 text-[10px] font-medium uppercase tracking-widest text-muted">Phone</p>
              <a href={`tel:${site.phoneTel}`} class="text-lg font-medium text-charcoal hover:text-gold">
                {site.phone}
              </a>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-stone bg-white shadow-sm">
              <span aria-hidden="true" class="text-gold">✉</span>
            </div>
            <div>
              <p class="mb-1 text-[10px] font-medium uppercase tracking-widest text-muted">Email</p>
              <a href={`mailto:${site.email}`} class="text-lg font-medium text-charcoal hover:text-gold">
                {site.email}
              </a>
            </div>
          </div>
        </div>
        <div class="mt-8">
          <a
            href="#contact"
            class="inline-flex items-center justify-center rounded-full bg-charcoal px-7 py-3 text-xs font-semibold uppercase tracking-[0.18em] text-white transition hover:bg-gold hover:text-charcoal"
          >
            Register EOI Now
          </a>
        </div>
      </div>

      <div class="relative rounded-[2rem] border border-stone/30 bg-white p-6 shadow-2xl sm:p-8 md:p-12">
        <div class="pointer-events-none absolute -right-6 -top-6 h-32 w-32 rounded-full bg-gold/10 blur-3xl"></div>
        <div class="pointer-events-none absolute -bottom-6 -left-6 h-40 w-40 rounded-full bg-stone/50 blur-3xl"></div>
        <ContactForm client:load />
      </div>
    </div>
  </div>
</section>
