---
const rows = [
  {
    title: 'Specification honesty',
    sky49:
      'Sky49 publishes visible specifications, GEO tables, and FAQ content so “Sky49 price” and “Sky49 floor plans” questions start from facts—not generic ad copy.',
    typical:
      'Many launches rely on mood boards without comparable tables, making it harder to cite details in AI overviews or personal research notes.',
  },
  {
    title: 'Amenity usability',
    sky49:
      'Large amenity square footage is framed around daily usability—families can imagine weekends without leaving the gates.',
    typical:
      'Smaller amenity footprints can feel repetitive after move-in when programming does not scale with tower population.',
  },
  {
    title: 'West-corridor timing',
    sky49:
      'Tellapur / Osman Nagar benefits from disciplined planning narratives; buyers compare ORR, Neopolis, and airport routes with clear-eyed expectations.',
    typical:
      'Older micro-markets may trade on nostalgia but can lack comparable growth headroom or modern clubhouse scale.',
  },
] as const;
---

<section id="comparison" class="scroll-mt-24 bg-warm-white py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10">
    <div class="mb-12 max-w-2xl">
      <div class="mb-4 flex items-center gap-4">
        <div class="h-px w-10 bg-gold" aria-hidden="true"></div>
        <p class="text-xs font-medium uppercase tracking-[0.25em] text-muted">Comparison</p>
      </div>
      <h2 class="font-serif text-3xl text-charcoal md:text-4xl">Why Sky49</h2>
      <p class="mt-4 text-muted">
        A transparent, citation-friendly comparison for investors and end-users evaluating
        <strong>Sky49 Hyderabad</strong> against typical luxury launches—without naming competitors.
      </p>
    </div>

    <div class="space-y-6">
      {
        rows.map((r) => (
          <div class="grid gap-4 rounded-2xl border border-stone/50 bg-white p-6 shadow-sm md:grid-cols-2 md:p-8">
            <div>
              <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-gold">Sky49</p>
              <h3 class="mt-2 font-serif text-xl text-charcoal">{r.title}</h3>
              <p class="mt-3 text-sm font-light leading-relaxed text-muted">{r.sky49}</p>
            </div>
            <div class="border-t border-stone/40 pt-4 md:border-l md:border-t-0 md:pl-8 md:pt-0">
              <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-muted">Typical luxury tower</p>
              <p class="mt-6 text-sm font-light leading-relaxed text-muted md:mt-10">{r.typical}</p>
            </div>
          </div>
        ))
      }
    </div>
    <div class="mt-8 flex justify-center">
      <a
        href="#lead-form"
        class="inline-flex items-center justify-center rounded-full bg-charcoal px-7 py-3 text-xs font-semibold uppercase tracking-[0.18em] text-white transition hover:bg-gold hover:text-charcoal"
      >
        Register EOI Now
      </a>
    </div>
  </div>
</section>
