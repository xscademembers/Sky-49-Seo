---
import { stats } from '../../data/site';
---

<section id="stats" class="border-y border-stone/50 bg-beige/50 py-10" aria-label="Project statistics">
  <div class="mx-auto grid max-w-7xl grid-cols-2 gap-6 px-4 sm:grid-cols-4 sm:px-6 lg:px-10">
    {
      stats.map((s) => (
        <div class="text-center">
          <p class="font-serif text-3xl text-charcoal md:text-4xl">{s.value}</p>
          <p class="mt-1 text-[10px] font-semibold uppercase tracking-[0.25em] text-muted">{s.label}</p>
        </div>
      ))
    }
  </div>
  <div class="mt-8 flex justify-center">
    <a
      href="#lead-form"
      class="inline-flex items-center justify-center rounded-full bg-charcoal px-7 py-3 text-xs font-semibold uppercase tracking-[0.18em] text-white transition hover:bg-gold hover:text-charcoal"
    >
      Register EOI Now
    </a>
  </div>
</section>
