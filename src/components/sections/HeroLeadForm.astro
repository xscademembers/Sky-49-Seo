<section id="hero-lead-form" class="scroll-mt-24 border-y border-stone/40 bg-beige/35 py-12 md:py-16">
  <div class="mx-auto grid max-w-7xl gap-8 px-4 sm:px-6 lg:grid-cols-12 lg:px-10">
    <div class="lg:col-span-6">
      <p class="text-xs font-medium uppercase tracking-[0.25em] text-muted">EOI desk</p>
      <h2 class="mt-3 font-serif text-3xl text-charcoal md:text-4xl">Register your detailed interest</h2>
      <p class="mt-3 max-w-xl text-sm font-light leading-relaxed text-muted md:text-base">
        Share your details for a complete walkthrough covering availability, tower options, and payment
        milestones.
      </p>
      <p class="mt-4 max-w-xl text-sm font-light leading-relaxed text-muted">
        RERA verification guidance, amenity sequencing insights, and brochure support are included in every
        advisory call.
      </p>
      <div class="mt-5 flex flex-wrap gap-2">
        <span class="rounded-full border border-stone/50 bg-white/80 px-3 py-1 text-[11px] font-medium uppercase tracking-wide text-charcoal">
          RERA guided
        </span>
        <span class="rounded-full border border-stone/50 bg-white/80 px-3 py-1 text-[11px] font-medium uppercase tracking-wide text-charcoal">
          1 lakh+ sq ft amenities
        </span>
        <span class="rounded-full border border-stone/50 bg-white/80 px-3 py-1 text-[11px] font-medium uppercase tracking-wide text-charcoal">
          Floor-plan advisory
        </span>
      </div>
      <a
        href="/#lead-form"
        class="mt-6 inline-flex items-center justify-center rounded-full border border-stone/50 bg-white px-6 py-3 text-xs font-semibold uppercase tracking-[0.18em] text-charcoal transition hover:border-gold/60"
      >
        Register EOI Now
      </a>
    </div>

    <div class="lg:col-span-6">
      <div class="rounded-2xl border border-stone/50 bg-white p-5 shadow-sm sm:p-6">
        <form class="space-y-4" aria-label="EOI detailed form">
          <label class="sr-only" for="lead-name">Your Name</label>
          <input
            id="lead-name"
            name="name"
            type="text"
            placeholder="Your Name"
            class="w-full rounded-none border border-stone/50 bg-white px-4 py-3 text-sm text-charcoal placeholder:text-muted focus:border-gold focus:outline-none"
            autocomplete="name"
          />

          <label class="sr-only" for="lead-phone">Phone Number</label>
          <input
            id="lead-phone"
            name="phone"
            type="tel"
            placeholder="Phone Number"
            class="w-full rounded-none border border-stone/50 bg-white px-4 py-3 text-sm text-charcoal placeholder:text-muted focus:border-gold focus:outline-none"
            autocomplete="tel"
          />

          <a
            href="#lead-form"
            class="inline-flex w-full items-center justify-between bg-charcoal px-6 py-4 text-sm font-semibold text-white transition hover:bg-gold hover:text-charcoal"
          >
            <span>Register EOI Now</span>
            <span aria-hidden="true">-&gt;</span>
          </a>
        </form>
      </div>
    </div>
  </div>
</section>
