---
import { projectGalleryImages } from '../../data/site';
---

<section id="project-gallery" class="scroll-mt-24 bg-[#efefef] py-16 md:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10">
    <p class="text-center text-[11px] font-semibold uppercase tracking-[0.2em] text-charcoal/70">
      Project Gallery
    </p>
    <h2 class="mt-3 text-center font-serif text-4xl text-charcoal sm:text-5xl md:text-6xl">
      Experience the Lifestyle Before You Live It
    </h2>

    <div class="mt-8 grid gap-4 md:grid-cols-3">
      {
        projectGalleryImages.map((img, i) => (
          <figure class="overflow-hidden bg-white/50">
            <img
              src={img.src}
              alt={img.alt}
              class="aspect-[16/10] w-full object-cover"
              loading={i < 3 ? 'eager' : 'lazy'}
              decoding="async"
            />
          </figure>
        ))
      }
    </div>
  </div>
</section>
