---
import { site } from '../data/site';

const y = new Date().getFullYear();
---

<footer class="border-t border-stone/40 bg-warm-white py-14" role="contentinfo">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10">
    <div class="grid gap-10 md:grid-cols-3">
      <div>
        <div>
          <p class="mt-3 font-serif text-2xl text-charcoal">{site.fullName}</p>
        </div>
        <p class="mt-3 text-sm font-light text-muted">
          {site.address.streetAddress}, {site.address.addressLocality}, {site.address.addressRegion}{' '}
          {site.address.postalCode}
        </p>
      </div>
      <div>
        <p class="text-[10px] font-semibold uppercase tracking-widest text-muted">Explore</p>
        <ul class="mt-4 space-y-2 text-sm">
          <li><a href="/#about" class="text-charcoal hover:text-gold">About Sky49</a></li>
          <li><a href="/#floor-plans" class="text-charcoal hover:text-gold">Floor plans</a></li>
          <li><a href="/#location" class="text-charcoal hover:text-gold">Location</a></li>
          <li><a href="/#faq" class="text-charcoal hover:text-gold">FAQ</a></li>
          <li><a href="/gallery" class="text-charcoal hover:text-gold">Gallery</a></li>
        </ul>
      </div>
      <div>
        <p class="text-[10px] font-semibold uppercase tracking-widest text-muted">Compliance</p>
        <p class="mt-4 text-sm font-light leading-relaxed text-muted">
          {site.rera}. Marketing collateral is indicative; verify on official portals before purchase.
        </p>
        <ul class="mt-4 space-y-2 text-sm">
          <li>
            <a href="/privacy-policy" class="text-charcoal hover:text-gold">Privacy policy</a>
          </li>
          <li>
            <a href="/terms-and-conditions" class="text-charcoal hover:text-gold">Terms and conditions</a>
          </li>
        </ul>
      </div>
    </div>
    <p class="mt-12 border-t border-stone/30 pt-8 text-center text-xs text-muted">
      © {y} {site.fullName}. Sky49 Hyderabad is a branded residential offering—availability and pricing subject
      to change.
    </p>
  </div>
</footer>
